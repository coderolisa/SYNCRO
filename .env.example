# Environment Configuration for Audit Logging System

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=audit_db
DB_USER=postgres
DB_PASSWORD=postgres

# Admin API Configuration
# Set a strong secret token for admin API access
ADMIN_API_KEY=your-super-secret-admin-key-change-me

# Optional: User Session Integration
# These are used to extract user_id from requests
# Uncomment and configure based on your auth system
# JWT_SECRET=your-jwt-secret
# SESSION_SECRET=your-session-secret

# Optional: IP Address Detection
# If running behind a proxy, ensure X-Forwarded-For header is passed
# PROXY_TRUST_HOP=1

# Optional: Logging Level
# Options: 'debug', 'info', 'warn', 'error'
# LOG_LEVEL=info

# Optional: Client-side Configuration
# These can be set at the client library initialization
# NEXT_PUBLIC_BATCH_SIZE=10
# NEXT_PUBLIC_BATCH_TIMEOUT=5000
# NEXT_PUBLIC_MAX_RETRIES=3

# Optional: Admin Panel URL (if you have one)
# NEXT_PUBLIC_ADMIN_PANEL_URL=/admin/audit-logs
